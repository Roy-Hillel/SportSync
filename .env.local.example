# Database (Supabase or any PostgreSQL — use the connection pooler URL)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# Auth.js — generate with: openssl rand -hex 32
AUTH_SECRET=your-auth-secret-here

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Sports data provider
SPORTRADAR_API_KEY=your-sportradar-api-key

# Cron security — generate with: openssl rand -hex 32
# Vercel sends this as a Bearer token to /api/cron/sync
CRON_SECRET=your-cron-secret-here

# App URL (no trailing slash)
# Dev: http://localhost:3000
# Prod: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
